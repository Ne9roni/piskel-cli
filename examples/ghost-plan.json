    { "command": "draw.pixel", "args": { "project": "examples-output/ghost/ghost.piskel", "frame": 2, "x": 10, "y": 3, "color": "#e2e8f0" } },
    { "command": "draw.pixel", "args": { "project": "examples-output/ghost/ghost.piskel", "frame": 2, "x": 11, "y": 3, "color": "#e2e8f0" } },
