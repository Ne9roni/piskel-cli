{
  "name": "@ne9roni/piskel-cli",
  "version": "1.0.0",
  "description": "Headless Piskel-compatible CLI probes",
  "type": "module",
  "main": "dist/src/cli.js",
  "bin": {
    "piskel-cli": "./dist/src/cli.js"
  },
  "scripts": {
    "sync-piskel-vendor": "node scripts/sync-piskel-vendor.mjs",
    "build": "tsc -p tsconfig.json",
    "build:reference-exe": "node scripts/build-reference-exe.mjs",
    "assert-vendor": "node scripts/assert-vendor.mjs",
    "prepublishOnly": "npm run build && npm test && npm run assert-vendor",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ne9roni/piskel-cli.git"
  },
  "homepage": "https://github.com/Ne9roni/piskel-cli#readme",
  "bugs": {
    "url": "https://github.com/Ne9roni/piskel-cli/issues"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "files": [
    "dist/src",
    "vendor/piskel-prod",
    "skills",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "dependencies": {
    "gifenc": "^1.0.3",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
